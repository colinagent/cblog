---
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '@layouts/BaseLayout.astro'
import BlogInsight from '@components/blog/BlogInsight.astro'
import HeroSectionAlt from '@components/blocks/HeroSectionAlt.astro'
import { getPosts, sortPostsByDate } from '../../support/content'
import { LOCALES, UI, type Locale } from '../../i18n'

export function getStaticPaths() {
    return LOCALES.map(locale => ({
        params: { locale },
        props: { locale },
    }))
}

const { locale } = Astro.props as { locale: Locale }
const t = UI[locale]
const posts: CollectionEntry<'posts'>[] = sortPostsByDate(await getPosts(false, locale)).slice(0, 3)
---

<BaseLayout title={t.pages.homeTitle} description={t.pages.homeDescription} lang={locale}>
    <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
        <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
            <h2 class="text-3xl font-bold text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
                {t.pages.latestPosts}
            </h2>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {
                posts.length > 0
                    ? posts.map(b => (
                        <BlogInsight blog={b} />
                    ))
                    : (
                        <div class="col-span-full rounded-xl border border-dashed border-neutral-300 p-10 text-center text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
                            {t.common.noPosts}
                        </div>
                    )
            }
        </div>
    </section>

    <HeroSectionAlt
        title="Follow Me"
        twitterUrl="https://x.com/colinagentcom"
        githubUrl="https://github.com/colinagent"
    />
</BaseLayout>
